# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Stellar ───────────────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Coordinator keypair used by the backend to release escrowed payments after
# each DAG node completes. When unset the backend logs a warning and skips
# payment release (safe for local dev and CI without a live Stellar connection).
# Generate a funded testnet keypair at https://laboratory.stellar.org/#account-creator
STELLAR_COORDINATOR_SECRET=S...your_coordinator_secret_key_here

# Secret key for the Coordinator account on Stellar testnet.
# Required for live Stellar E2E tests (STELLAR_E2E=1).
STELLAR_TEST_SECRET=S...your_testnet_secret_key_here

# ── Venice AI ─────────────────────────────────────────────────────────────────
# Required for live agent execution (mocked in E2E tests).
# Get a key at https://venice.ai
VENICE_API_KEY=your_venice_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ainet
